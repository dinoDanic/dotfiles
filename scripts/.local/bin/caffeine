#!/bin/bash

# Toggle hypridle on/off (caffeine mode)
# When off: no auto-lock, no screen dimming, no DPMS

if pgrep -x hypridle > /dev/null; then
    killall hypridle
    notify-send "Caffeine ON" "Screen will stay awake" -i display-brightness-symbolic
else
    hypridle &
    disown
    notify-send "Caffeine OFF" "Idle lock restored" -i preferences-desktop-screensaver-symbolic
fi
